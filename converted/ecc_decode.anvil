    left double_error_o : (logic@#1) @dyn - @dyn
}

proc ecc_decode(
    in_ep : left ecc_decode_in_ch,
    out_ep : right ecc_decode_out_ch
) {
    reg r_data_i : logic[64];

    loop {
        let data_i = recv in_ep.data_i >>
        set r_data_i := data_i
