/* Anvil translation of spike
   Generated by sv2anvil.py (AST-based converter) */

chan spike_in_ch {
    left clint_tick_i : (logic@#1) @dyn - @dyn,
    left rvfi_i : (logic[64]@#1) @dyn - @dyn,
    left rvfi_csr_i : (logic[64]@#1) @dyn - @dyn
}

chan spike_out_ch {
    left end_of_test_o : (logic[32]@#1) @dyn - @dyn
}

proc spike(
    in_ep : left spike_in_ch,
    out_ep : right spike_out_ch
) {
    loop {
        send out_ep.end_of_test_o (32'd0) >>
        cycle 1
    }

}

