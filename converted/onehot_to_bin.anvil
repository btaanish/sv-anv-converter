/* Anvil translation of onehot_to_bin
   Generated by sv2anvil.py (AST-based converter) */

chan onehot_to_bin_in_ch {
    left onehot : (logic[16]@#1) @dyn - @dyn
}

chan onehot_to_bin_out_ch {
    left bin : (logic[32]@#1) @dyn - @dyn
}

proc onehot_to_bin(
    in_ep : left onehot_to_bin_in_ch,
    out_ep : right onehot_to_bin_out_ch
) {
    loop {
        let _onehot = recv in_ep.onehot >>
        send out_ep.bin (32'd0) >>
        cycle 1
    }

}

