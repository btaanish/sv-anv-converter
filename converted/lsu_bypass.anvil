    };

    // Apply write to the correct FIFO slot          // [MANUAL]
    let mem_after_write_0 = if (lsu_req_valid_i && (*write_pointer_q == 1'b0)) {
        req_to_store                                                        // [MANUAL]
    } else {
        mem_n_0                                                             // [MANUAL]
    };
    let mem_after_write_1 = if (lsu_req_valid_i && (*write_pointer_q == 1'b1)) {
        req_to_store                                                        // [MANUAL]
    } else {
        mem_n_1                                                             // [MANUAL]
    };

    // Update write pointer and status count after write // [MANUAL]
    let write_pointer_after_write = if lsu_req_valid_i {
        *write_pointer_q ^ 1'b1                                             // [MANUAL] 1-bit increment
    } else {
        write_pointer_base                                                  // [MANUAL]
    };
    let status_cnt_after_write = if lsu_req_valid_i {
        status_cnt_base + 2'b01                                             // [MANUAL]
    } else {
        status_cnt_base                                                     // [MANUAL]
    };

    // --- Pop path: pop_ld_i or pop_st_i ---        // [MANUAL]
    // In SV, pop_ld and pop_st each independently invalidate mem[read_pointer]
    // and increment read_pointer / decrement status_cnt.
    // If both pop, mem is fully cleared.
    let pop_any = pop_ld_i || pop_st_i;                                     // [MANUAL]
    let pop_both = pop_ld_i && pop_st_i;                                    // [MANUAL]

    // Invalidate read slot on single pop            // [MANUAL]
    // [MANUAL-CLEANUP-NEEDED] struct field override — .valid = 0
    let mem_after_pop_0 = if pop_both {
        0                                                                   // [MANUAL-CLEANUP-NEEDED] lsu_ctrl_t zero
    } else if (pop_any && (*read_pointer_q == 1'b0)) {
        lsu_ctrl_t::{ ..mem_after_write_0; valid = 1'b0; }                  // [MANUAL-CLEANUP-NEEDED] struct update syntax
    } else {
        mem_after_write_0                                                   // [MANUAL]
    };
    let mem_after_pop_1 = if pop_both {
        0                                                                   // [MANUAL-CLEANUP-NEEDED] lsu_ctrl_t zero
    } else if (pop_any && (*read_pointer_q == 1'b1)) {
        lsu_ctrl_t::{ ..mem_after_write_1; valid = 1'b0; }                  // [MANUAL-CLEANUP-NEEDED] struct update syntax
    } else {
        mem_after_write_1                                                   // [MANUAL]
    };

    // In SV, if both pop_ld and pop_st fire, read_pointer increments twice (net 0),
    // and status_cnt decrements twice. If only one pops, single increment/decrement.
    let pop_count = if pop_both { 2'b10 } else if pop_any { 2'b01 } else { 2'b00 };  // [MANUAL]
    let read_pointer_after_pop = if pop_any {
        read_pointer_base ^ 1'b1                                            // [MANUAL] 1-bit toggle (works for single pop; both pops net-zero handled by flush-like clear)
    } else {
        read_pointer_base                                                   // [MANUAL]
    };
    let status_cnt_after_pop = status_cnt_after_write - pop_count;          // [MANUAL]

    // --- Flush path ---                            // [MANUAL]
    let mem_n_final_0 = if flush_i { 0 } else { mem_after_pop_0 };          // [MANUAL-CLEANUP-NEEDED] lsu_ctrl_t zero
    let mem_n_final_1 = if flush_i { 0 } else { mem_after_pop_1 };          // [MANUAL-CLEANUP-NEEDED] lsu_ctrl_t zero
    let read_pointer_n = if flush_i { 1'b0 } else { read_pointer_after_pop };   // [MANUAL]
    let write_pointer_n = if flush_i { 1'b0 } else { write_pointer_after_write }; // [MANUAL]
    let status_cnt_n = if flush_i { 2'b00 } else { status_cnt_after_pop };  // [MANUAL]

    // --- Output assignment ---                     // [MANUAL]
    // When FIFO is empty, pass through the incoming request directly;
