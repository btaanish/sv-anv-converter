    let lsu_ctrl_o = if empty {                                             // [MANUAL]
        lsu_req_i                                                           // [AUTO]
    } else {
        if (*read_pointer_q == 1'b0) { *mem_q_0 } else { *mem_q_1 }        // [MANUAL]
