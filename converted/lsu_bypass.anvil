    pop_st_i : right logic,                         // [AUTO]
    resolved_branch_i : right bp_resolve_t,         // [AUTO]
    lsu_ctrl_o : left lsu_ctrl_t,                   // [AUTO]
    ready_o : left logic                            // [AUTO]
