    reg write_pointer_q : logic;                    // [AUTO]
    reg status_cnt_q : (logic[2]);                  // [AUTO]

    // Combinational: empty and ready               // [AUTO]
    let empty = (*status_cnt_q == 2'b00);           // [MANUAL] explicit width
    let ready_o = empty;                            // [AUTO]

    // --- Combinational next-state logic ---        // [MANUAL]
    // Model the SV automatic-variable block as a chain of let bindings.
    // Since pointers are 1-bit, increment is XOR with 1.

    // Base next-state values (default: hold current) // [MANUAL]
    let mem_n_0 = *mem_q_0;                         // [MANUAL]
    let mem_n_1 = *mem_q_1;                         // [MANUAL]
    let status_cnt_base = *status_cnt_q;            // [MANUAL]
    let write_pointer_base = *write_pointer_q;      // [MANUAL]
    let read_pointer_base = *read_pointer_q;        // [MANUAL]

    // --- Write path: lsu_req_valid_i ---           // [MANUAL]
    // When valid, store request at write_pointer_q position and apply
    // speculative-load resolution if applicable.
    let req_to_store = if (lsu_req_i.is_speculative_load && resolved_branch_i.valid) {
        if resolved_branch_i.is_mispredict {                                // [MANUAL]
            lsu_ctrl_t::{ ..lsu_req_i; is_speculative_load_miss = 1'b1; }  // [MANUAL-CLEANUP-NEEDED] struct update syntax
        } else {                                                            // [MANUAL]
            lsu_ctrl_t::{ ..lsu_req_i; is_speculative_load = 1'b0; }       // [MANUAL-CLEANUP-NEEDED] struct update syntax
        }
    } else {
