    // Register declarations                        // [MANUAL]
    reg mem_q_0 : lsu_ctrl_t;                       // [MANUAL] mem_q[0] — split from array since Anvil lacks indexed array reg write
    reg mem_q_1 : lsu_ctrl_t;                       // [MANUAL] mem_q[1]
