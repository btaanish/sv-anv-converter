                      & {CDom_reduced4SigExtra_shift[1..13]}})
                  | (doSubMags ? mulAddResult[52:0]!=53'h1FFFFFFFFFFFFF : |(mulAddResult[53:0]))}
           = 55 bits high + 1 sticky = 56 bits

           notCDom: {notCDom_mainSig_T[109:55],
                     |{notCDom_mainSig_T[54:52],
                        {|{|(n[51:50]),|(n[49:48])}, ..., |{|(n[3:2]),|(n[1:0])}} (13 groups)
                        & {notCDom_reduced4SigExtra_shift[1..13]}}}
           = 55 bits high + 1 sticky = 56 bits */

        /* CDom sig */
        let cdom_main_107_53 = <(CDom_mainSig_T >> <(53)::logic[171]>)::logic[55]> >>
        let cdom_main_52_50  = <(CDom_mainSig_T >> <(50)::logic[171]>)::logic[3]> >>
        let cabs_49_46 = <(CDom_absSigSum >> <(46)::logic[108]>)::logic[4]> >>
        let cabs_45_42 = <(CDom_absSigSum >> <(42)::logic[108]>)::logic[4]> >>
        let cabs_41_38 = <(CDom_absSigSum >> <(38)::logic[108]>)::logic[4]> >>
        let cabs_37_34 = <(CDom_absSigSum >> <(34)::logic[108]>)::logic[4]> >>
        let cabs_33_30 = <(CDom_absSigSum >> <(30)::logic[108]>)::logic[4]> >>
        let cabs_29_26 = <(CDom_absSigSum >> <(26)::logic[108]>)::logic[4]> >>
        let cabs_25_22 = <(CDom_absSigSum >> <(22)::logic[108]>)::logic[4]> >>
        let cabs_21_18 = <(CDom_absSigSum >> <(18)::logic[108]>)::logic[4]> >>
        let cabs_17_14 = <(CDom_absSigSum >> <(14)::logic[108]>)::logic[4]> >>
        let cabs_13_10 = <(CDom_absSigSum >> <(10)::logic[108]>)::logic[4]> >>
        let cabs_9_6   = <(CDom_absSigSum >> <(6)::logic[108]>)::logic[4]> >>
        let cabs_5_2   = <(CDom_absSigSum >> <(2)::logic[108]>)::logic[4]> >>
        let cabs_1_0   = <(CDom_absSigSum)::logic[2]> >>
        let c_r4_1  = CDom_reduced4SigExtra_shift [ 1 ] >>
