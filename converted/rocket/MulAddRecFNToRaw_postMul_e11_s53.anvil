        let c_r4_3  = CDom_reduced4SigExtra_shift [ 3 ] >>
        let c_r4_4  = CDom_reduced4SigExtra_shift [ 4 ] >>
        let c_r4_5  = CDom_reduced4SigExtra_shift [ 5 ] >>
        let c_r4_6  = CDom_reduced4SigExtra_shift [ 6 ] >>
        let c_r4_7  = CDom_reduced4SigExtra_shift [ 7 ] >>
        let c_r4_8  = CDom_reduced4SigExtra_shift [ 8 ] >>
        let c_r4_9  = CDom_reduced4SigExtra_shift [ 9 ] >>
        let c_r4_10 = CDom_reduced4SigExtra_shift [ 10 ] >>
        let c_r4_11 = CDom_reduced4SigExtra_shift [ 11 ] >>
        let c_r4_12 = CDom_reduced4SigExtra_shift [ 12 ] >>
        let c_r4_13 = CDom_reduced4SigExtra_shift [ 13 ] >>
        let cdom_extra_bits = #{(cabs_49_46 != <(0)::logic[4]>), (cabs_45_42 != <(0)::logic[4]>), (cabs_41_38 != <(0)::logic[4]>), (cabs_37_34 != <(0)::logic[4]>), (cabs_33_30 != <(0)::logic[4]>), (cabs_29_26 != <(0)::logic[4]>), (cabs_25_22 != <(0)::logic[4]>), (cabs_21_18 != <(0)::logic[4]>), (cabs_17_14 != <(0)::logic[4]>), (cabs_13_10 != <(0)::logic[4]>), (cabs_9_6 != <(0)::logic[4]>), (cabs_5_2 != <(0)::logic[4]>), (cabs_1_0 != <(0)::logic[2]>)} & #{c_r4_1, c_r4_2, c_r4_3, c_r4_4, c_r4_5, c_r4_6, c_r4_7, c_r4_8, c_r4_9, c_r4_10, c_r4_11, c_r4_12, c_r4_13} >>
