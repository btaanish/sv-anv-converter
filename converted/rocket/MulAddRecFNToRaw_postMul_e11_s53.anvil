        send out_ep.io_rawOut_isInf (<(notNaN_isInfOut)::logic>) >>
        send out_ep.io_rawOut_isZero (<(io_rawOut_isZero)::logic>) >>
        send out_ep.io_rawOut_sign (<(io_rawOut_sign)::logic>) >>
        send out_ep.io_rawOut_sExp (<(io_rawOut_sExp)::logic[13]>) >>
        send out_ep.io_rawOut_sig (<(io_rawOut_sig)::logic[56]>) >>
        cycle 1
    }

