        let nc_extra = #{nc_grp0, nc_grp1, nc_grp2, nc_grp3, nc_grp4, nc_grp5, nc_grp6, nc_grp7, nc_grp8, nc_grp9, nc_grp10, nc_grp11, nc_grp12} & #{nc_r4_1, nc_r4_2, nc_r4_3, nc_r4_4, nc_r4_5, nc_r4_6, nc_r4_7, nc_r4_8, nc_r4_9, nc_r4_10, nc_r4_11, nc_r4_12, nc_r4_13} >>
