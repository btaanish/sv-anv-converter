) { <(8589934576)::logic[33]> } else { if (nd_5_1 == <(2)::logic[5]>) { <(8589934584)::logic[33]> } else { if (nd_5_1 == <(1)::logic[5]>) { <(8589934588)::logic[33]> } else { <(8589934590)::logic[33]> } } } } } } } } } } } } } } } } } } } } } } } } } } } } } } } >>

        /* notCDom_completeCancellation: notCDom_mainSig_T[109:108] == 0 */
        let nc_main_109_108 = <(notCDom_mainSig_T >> <(108)::logic[236]>)::logic[2]> >>
        let notCDom_completeCancellation = nc_main_109_108 == <(0)::logic[2]> >>

        let notNaN_isInfProd = isInfA | isInfB >>
        let notNaN_isInfOut = notNaN_isInfProd | isInfC >>
        let notNaN_addZeros = (isZeroA | isZeroB) & isZeroC >>

        let io_invalidExc = isSigNaNAny | (isInfA & isZeroB) | (isZeroA & isInfB) | (~isNaNAOrB & notNaN_isInfProd & isInfC & doSubMags) >>
        let io_rawOut_isNaN = isNaNAOrB | isNaNC >>
