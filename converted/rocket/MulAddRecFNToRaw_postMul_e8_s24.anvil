        let nd_4_1 = <(notCDom_normDistReduced2 >> <(1)::logic[5]>)::logic[4]> >>
        let notCDom_reduced4SigExtra_shift = if (nd_4_1 == <(15)::logic[4]>) { <(65536)::logic[17]> } else { if (nd_4_1 == <(14)::logic[4]>) { <(98304)::logic[17]> } else { if (nd_4_1 == <(13)::logic[4]>) { <(114688)::logic[17]> } else { if (nd_4_1 == <(12)::logic[4]>) { <(122880)::logic[17]> } else { if (nd_4_1 == <(11)::logic[4]>) { <(126976)::logic[17]> } else { if (nd_4_1 == <(10)::logic[4]>) { <(129024)::logic[17]> } else { if (nd_4_1 == <(9)::logic[4]>) { <(130048)::logic[17]> } else { if (nd_4_1 == <(8)::logic[4]>) { <(130560)::logic[17]> } else { if (nd_4_1 == <(7)::logic[4]>) { <(130816)::logic[17]> } else { if (nd_4_1 == <(6)::logic[4]>) { <(130944)::logic[17]> } else { if (nd_4_1 == <(5)::logic[4]>) { <(131008)::logic[17]> } else { if (nd_4_1 == <(4)::logic[4]>) { <(131040)::logic[17]> } else { if (nd_4_1 == <(3)::logic[4]>) { <(131056)::logic[17]> } else { if (nd_4_1 == <(2)::logic[4]>) { <(131064)::logic[17]> } else { if (nd_4_1 == <(1)::logic[4]>) { <(131068)::logic[17]> } else { <(131070)::logic[17]> } } } } } } } } } } } } } } } >>

