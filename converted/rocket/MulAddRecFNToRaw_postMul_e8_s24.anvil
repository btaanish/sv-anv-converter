        let cdom_r4_3 = CDom_reduced4SigExtra_shift [ 3 ] >>
        let cdom_r4_4 = CDom_reduced4SigExtra_shift [ 4 ] >>
        let cdom_r4_5 = CDom_reduced4SigExtra_shift [ 5 ] >>
        let cdom_r4_6 = CDom_reduced4SigExtra_shift [ 6 ] >>
        let cdom_extra_bits = #{(cdom_abs_20_17 != <(0)::logic[4]>), (cdom_abs_16_13 != <(0)::logic[4]>), (cdom_abs_12_9 != <(0)::logic[4]>), (cdom_abs_8_5 != <(0)::logic[4]>), (cdom_abs_4_1 != <(0)::logic[4]>), cdom_abs_0} & #{cdom_r4_1, cdom_r4_2, cdom_r4_3, cdom_r4_4, cdom_r4_5, cdom_r4_6} >>
        let cdom_or_bits = (cdom_main_23_21 != <(0)::logic[3]>) | (cdom_extra_bits != <(0)::logic[6]>) >>
        let mar_23_0 = <(mulAddResult)::logic[24]> >>
        let mar_24_0 = <(mulAddResult)::logic[25]> >>
        let cdom_tail = if doSubMags { mar_23_0 != <(16777215)::logic[24]> } else { mar_24_0 != <(0)::logic[25]> } >>
        let cdom_sticky = cdom_or_bits | cdom_tail >>
        let cdom_sig = (<(cdom_main_49_24)::logic[27]> << <(1)::logic[27]>) | <(<(cdom_sticky)::logic[27]>)::logic[27]> >>

        /* notCDom sig */
        let nc_main_51_26 = <(notCDom_mainSig_T >> <(26)::logic[114]>)::logic[26]> >>
        let nc_main_25_23 = <(notCDom_mainSig_T >> <(23)::logic[114]>)::logic[3]> >>
        let nc_23_22b = <(notCDom_absSigSum >> <(22)::logic[51]>)::logic[2]> >>
        let nc_21_20b = <(notCDom_absSigSum >> <(20)::logic[51]>)::logic[2]> >>
        let nc_19_18b = <(notCDom_absSigSum >> <(18)::logic[51]>)::logic[2]> >>
        let nc_17_16b = <(notCDom_absSigSum >> <(16)::logic[51]>)::logic[2]> >>
        let nc_15_14b = <(notCDom_absSigSum >> <(14)::logic[51]>)::logic[2]> >>
        let nc_13_12b = <(notCDom_absSigSum >> <(12)::logic[51]>)::logic[2]> >>
        let nc_11_10b = <(notCDom_absSigSum >> <(10)::logic[51]>)::logic[2]> >>
        let nc_9_8b  = <(notCDom_absSigSum >> <(8)::logic[51]>)::logic[2]> >>
        let nc_7_6b  = <(notCDom_absSigSum >> <(6)::logic[51]>)::logic[2]> >>
        let nc_5_4b  = <(notCDom_absSigSum >> <(4)::logic[51]>)::logic[2]> >>
        let nc_3_2b  = <(notCDom_absSigSum >> <(2)::logic[51]>)::logic[2]> >>
        let nc_1_0b  = <(notCDom_absSigSum)::logic[2]> >>
        let nc_grp0 = (nc_23_22b != <(0)::logic[2]>) | (nc_21_20b != <(0)::logic[2]>) >>
        let nc_grp1 = (nc_19_18b != <(0)::logic[2]>) | (nc_17_16b != <(0)::logic[2]>) >>
        let nc_grp2 = (nc_15_14b != <(0)::logic[2]>) | (nc_13_12b != <(0)::logic[2]>) >>
        let nc_grp3 = (nc_11_10b != <(0)::logic[2]>) | (nc_9_8b != <(0)::logic[2]>) >>
        let nc_grp4 = (nc_7_6b != <(0)::logic[2]>) | (nc_5_4b != <(0)::logic[2]>) >>
        let nc_grp5 = (nc_3_2b != <(0)::logic[2]>) | (nc_1_0b != <(0)::logic[2]>) >>
        let nc_r4_1 = notCDom_reduced4SigExtra_shift [ 1 ] >>
        let nc_r4_2 = notCDom_reduced4SigExtra_shift [ 2 ] >>
        let nc_r4_3 = notCDom_reduced4SigExtra_shift [ 3 ] >>
        let nc_r4_4 = notCDom_reduced4SigExtra_shift [ 4 ] >>
        let nc_r4_5 = notCDom_reduced4SigExtra_shift [ 5 ] >>
        let nc_r4_6 = notCDom_reduced4SigExtra_shift [ 6 ] >>
        let nc_extra = #{nc_grp0, nc_grp1, nc_grp2, nc_grp3, nc_grp4, nc_grp5} & #{nc_r4_1, nc_r4_2, nc_r4_3, nc_r4_4, nc_r4_5, nc_r4_6} >>
        let nc_sticky = (nc_main_25_23 != <(0)::logic[3]>) | (nc_extra != <(0)::logic[6]>) >>
        let ncdm_sig = (<(nc_main_51_26)::logic[27]> << <(1)::logic[27]>) | <(<(nc_sticky)::logic[27]>)::logic[27]> >>

        let io_rawOut_sig = if CIsDominant { cdom_sig } else { ncdm_sig } >>

        send out_ep.io_invalidExc (<(io_invalidExc)::logic>) >>
        send out_ep.io_rawOut_isNaN (<(io_rawOut_isNaN)::logic>) >>
        send out_ep.io_rawOut_isInf (<(notNaN_isInfOut)::logic>) >>
        send out_ep.io_rawOut_isZero (<(io_rawOut_isZero)::logic>) >>
        send out_ep.io_rawOut_sign (<(io_rawOut_sign)::logic>) >>
        send out_ep.io_rawOut_sExp (<(io_rawOut_sExp)::logic[10]>) >>
        send out_ep.io_rawOut_sig (<(io_rawOut_sig)::logic[27]>) >>
        cycle 1
    }

}
